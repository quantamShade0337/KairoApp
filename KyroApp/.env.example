# ─────────────────────────────────────────────
# Kyro — Environment Variables Example
# Rename to .env.local and fill in your values
# Never commit your real .env.local to git
# ─────────────────────────────────────────────

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────
# https://supabase.com → New Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── GitHub OAuth App ──────────────────────────
# https://github.com/settings/developers → OAuth Apps → New
# Callback: http://localhost:3000/api/auth/github-callback
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Session Secret ────────────────────────────
# Run: openssl rand -base64 32
SESSION_SECRET=replace-with-openssl-rand-base64-32-output
